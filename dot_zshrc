#!/bin/zsh
# ────────────────────── Helper config functions ───────────────────────────────

# Check if command exists then aliases
safe_alias() {
    local arg="$1"

    # Parse alias name and value
    local alias_name="${arg%%=*}"
    alias_name="${alias_name// /}"

    local alias_value="${arg#*=}"
    alias_value="${alias_value#"${alias_value%%[! ]*}"}"
    alias_value="${alias_value%"${alias_value##*[! ]}"}"
    alias_value="${alias_value#\"}"
    alias_value="${alias_value%\"}"
    alias_value="${alias_value#\'}"
    alias_value="${alias_value%\'}"

    # Extract the executable (first token)
    local executable="${alias_value%% *}"

    # Check existence: absolute path uses -f, bare name uses command -v
    local found=0
    if [[ "$executable" == /* ]]; then
        [[ -f "$executable" ]] && found=1
    else
        command -v "$executable" &>/dev/null && found=1
    fi

    if ((found)); then
        alias "${alias_name}=${alias_value}"
    else
        if [[ ! -f "$HOME/.config/SUPRESS_WARNINGS" ]]; then
            echo "safe_alias: warning: '${executable}' not found — alias '${alias_name}' was not set." >&2
        fi
    fi
}

# Check if file exists and source
safe_source() {
    [[ -e "$1" ]] && source "$1"
}

# ────────────────────── oh-my-zsh Config ──────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
export ZSH_COMPDUMP="$ZSH/cache/.zcompdump-$HOST"

ZSH_THEME="sunrise"

HYPHEN_INSENSITIVE="true"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"

source <(fzf --zsh)

zstyle ':omz:update' mode auto # update automatically without asking


# ────────────────────────────── Global VARS ───────────────────────────────────
export GITHUB_USERNAME=PetricaT

# ──────────────────────────── OS Specific setups ──────────────────────────────
#                                   MacOS 🍎
# ──────────────────────────────────────────────────────────────────────────────
if [[ "$OSTYPE" == "darwin"* ]]; then
    # Exports
    export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
    export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"

    export HOMEBREW_SHARE="$HOMEBREW_PREFIX/share"

    # pnpm
    export PNPM_HOME="~/Library/pnpm"
    case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
    esac
    # pnpm end
    
  # Aliases
    safe_alias pip="python3 -m pip"
    safe_alias python="python3"

  # Sources
  safe_source ${HOME}/.iterm2_shell_integration.zsh 
  safe_source "$HOMEBREW_SHARE/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

  plugins=(
        z
        brew
        iterm2
        zsh-autosuggestions
    )

# ──────────────────────────────────────────────────────────────────────────────
#                                   Linux 🐧
# ──────────────────────────────────────────────────────────────────────────────
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Exports
    ## Languages
    export LANG=en_US.UTF-8
    export LC_CTYPE=en_US.UTF-8
    export LC_NUMERIC=en_US.UTF-8
    export LC_TIME=ro_RO.UTF-8
    export LC_COLLATE=en_US.UTF-8
    export LC_MONETARY=ro_RO.UTF-8
    export LC_MESSAGES=en_US.UTF-8
    export LC_PAPER=ro_RO.UTF-8
    export LC_NAME=ro_RO.UTF-8
    export LC_ADDRESS=ro_RO.UTF-8
    export LC_TELEPHONE=ro_RO.UTF-8
    export LC_MEASUREMENT=ro_RO.UTF-8
    export LC_IDENTIFICATION=ro_RO.UTF-8

    ## System env
    export EDITOR=nvim
    export GCM_CREDENTIAL_STORE=secretservice

    ## Add MangoHUD to path
    export PATH="$PATH:/usr/bin/mangohud:/usr/lib/mangohud:/usr/lib32/mangohud"
    export PATH="$PATH:$HOME/.cache/.bun/bin"

    for file in \
        ~/.oh-my-zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
        /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh; do
        [ -f "$file" ] && source "$file" && break
    done

    if command -v zoxide >/dev/null 2>&1; then
        eval "$(zoxide init zsh)"
    fi


    # Aliases
    alias open="xdg-open"
    # alias wpeek="watch -n.1 /usr/local/bin/wpeek.sh"

    ## [Completion]
    ## Completion scripts setup. Remove the following line to uninstall
    [[ -f $HOME/.dart-cli-completion/zsh-config.zsh ]] && . $HOME/.dart-cli-completion/zsh-config.zsh || true
    ## [/Completion]

    # Created by `pipx` on 2025-06-03 16:48:28
    export PATH="$PATH:$HOME/.local/bin"
    safe_source "$HOME/.jabba/jabba.sh"
    # [ -s "$HOME/.jabba/jabba.sh" ] && source "$HOME/.jabba/jabba.sh"

    plugins=(
        zoxide
        zsh-autosuggestions
        colored-man-pages
    )

fi
# ──────────────────────────────────────────────────────────────────────────────
#                         END OF OS-SPECIFIC CONFIGS
# ──────────────────────────────────────────────────────────────────────────────

safe_source "$ZSH/oh-my-zsh.sh"

